nextflow.enable.dsl = 2

// Real-time monitoring and logging — all output goes to user's launch directory
timeline {
    enabled = true
    file = "${launchDir}/timeline.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${launchDir}/trace.txt"
    overwrite = true
}

report {
    enabled = true
    file = "${launchDir}/report.html"
    overwrite = true
}

dag {
    enabled = true
    file = "${launchDir}/dag.html"
    overwrite = true
}

// Real-time progress updates
log {
    level = 'info'
    file = "${launchDir}/nextflow.log"
    append = false
}

// Enable real-time process monitoring
monitor {
    enabled = true
    interval = '30s'
}

// Enable process output streaming
process {
    publishDir = [:]
    publishDir.mode = 'copy'
    publishDir.overwrite = true
}

process {
    executor = 'slurm'               // Use SLURM cluster scheduler
    queue = 'galaxy'                 // Your SLURM queue or partition
    cpus =  1                        // CPUs per task
    memory = '15GB'                  // Memory per task
    time = '600h'                      // Max run time
    maxForks = 22    // max concurrent jobs
    queueSize = 50   // optional, buffers more jobs
    

    container = '/gladstone/finkbeiner/steve/work/projects/nextflow-cluster/nextflow-cluster.sif'
   // containerEngine = 'apptainer'
    containerOptions = "--bind /gladstone/finkbeiner/steve/work/projects/nextflow-cluster/bin:/app \
                        --bind /gladstone/finkbeiner:/gladstone/finkbeiner:rw \
                        --nv"
   
    shell = ['/bin/bash']
}

