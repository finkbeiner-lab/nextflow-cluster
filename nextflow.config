nextflow.enable.dsl = 2

// All Nextflow task scratch dirs (the hashed aa/bb...  subtree) land here,
// regardless of where the pipeline was launched from. Nextflow hashes by
// task content, so a shared root is safe across runs and lets `-resume`
// benefit from prior runs' cache hits.
//
// Kept next to the editor state at /gladstone/.../deepcell-db so all
// deepcell-scoped state lives under one root. Manual `sbatch run.sh`
// launches from anywhere else on the cluster will also write here.
workDir = '/gladstone/finkbeiner/steve/work/projects/deepcell-db/work'

// Real-time monitoring and logging — all output goes to user's launch directory
timeline {
    enabled = true
    file = "${launchDir}/timeline.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${launchDir}/trace.txt"
    overwrite = true
}

report {
    enabled = true
    file = "${launchDir}/report.html"
    overwrite = true
}

dag {
    enabled = true
    file = "${launchDir}/dag.html"
    overwrite = true
}

// Real-time progress updates
log {
    level = 'info'
    file = "${launchDir}/nextflow.log"
    append = false
}

// Enable real-time process monitoring
monitor {
    enabled = true
    interval = '30s'
}

// Executor-level caps (must live outside the `process` scope to be honoured).
// queueSize: max tasks Nextflow will hold in the Slurm queue at once
//   (pending + running). Above this, tasks stay in Nextflow's internal buffer.
// submitRateLimit: throttle burst submissions so we don't slam Slurm's scheduler
//   when a stage of ~90 wells goes runnable simultaneously.
executor {
    queueSize = 100
    submitRateLimit = '10 sec'
}

// Enable process output streaming
process {
    publishDir = [:]
    publishDir.mode = 'copy'
    publishDir.overwrite = true
}

process {
    executor = 'slurm'               // Use SLURM cluster scheduler
    queue = 'galaxy'                 // Your SLURM queue or partition
    cpus =  1                        // CPUs per task
    memory = '15GB'                  // Memory per task
    time = '7d'                        // Max run time (7 days = 168h)
    maxForks = 22    // max concurrent jobs


    container = '/gladstone/finkbeiner/steve/work/projects/nextflow-cluster/nextflow-cluster.sif'
   // containerEngine = 'apptainer'
    containerOptions = "--bind /gladstone/finkbeiner/steve/work/projects/nextflow-cluster/bin:/app \
                        --bind /gladstone/finkbeiner:/gladstone/finkbeiner:rw \
                        --nv"

    shell = ['/bin/bash']

    // Propagate the experiment output_path into every task so
    // bin/experiment_logger.py can write to <output_path>/pipeline_debug.log.
    // See bin/experiment_logger.py + pipeline.nf's RUN START header.
    // Closure = lazy evaluation at task-launch time. A plain GString would be
    // evaluated at config-parse time where `params` resolves to `process.params`
    // and Nextflow rejects it as an unknown attribute.
    beforeScript = { "export NEXTFLOW_OUTPUT_PATH='${params.output_path ?: ''}'" }
}

