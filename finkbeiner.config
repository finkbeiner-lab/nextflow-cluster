/* ============================================================================
 * Finkbeiner Lab - Nextflow Pipeline Configuration
 * ============================================================================
 * Edit this file to control which steps run and how they are parameterised.
 *
 * Usage:
 *   sbatch /gladstone/finkbeiner/steve/work/projects/nextflow-cluster/run.sh \
 *          -c finkbeiner.config
 *
 * Tips:
 *   - Set ONE workflow flag below (DO_STD_WORKFLOW or DO_STD_WORKFLOW_IXM)
 *     OR enable individual DO_* modules. Avoid mixing the two.
 *   - All boolean values are lowercase: true / false
 *   - All string values must be quoted: 'value'
 *   - For lists use bracket form: ['FITC', 'RFP']
 *   - Comments use '//' (NOT '#')
 *   - Nextflow doc: https://nextflow-io.github.io/patterns/conditional-process/
 * ============================================================================
 */


// ============================================================================
// 1. WORKFLOW SELECTION  (pick ONE — leave both false to run individual modules)
// ============================================================================
params.DO_STD_WORKFLOW       = false   // MONTAGE -> ALIGN -> SEG -> TRACK -> OVERLAY
params.DO_STD_WORKFLOW_IXM   = false   // MONTAGE -> SEG -> TRACK -> OVERLAY (no align)


// ============================================================================
// 2. INDIVIDUAL MODULE TOGGLES  (only used when no bundled workflow is on)
// ============================================================================
params.DO_REGISTER_EXPERIMENT     = true    // First-time experiment setup
params.DO_UPDATEPATHS             = false
params.DO_VIEW_NORMALIZATION_IMAGES = false
params.DO_COPY_MASK_TO_TRACKED    = false   // Include T0 mask for crop-tracking
params.DO_ALIGN_TILES_DFT         = false   // Tile-level alignment
params.DO_ALIGN_MONTAGE_DFT       = false   // Montage-level alignment
params.DO_SEGMENTATION            = false   // Tile-level segmentation
params.DO_SEGMENTATION_MONTAGE    = false   // Montage-level segmentation
params.DO_CELLPOSE_SEGMENTATION   = false
params.DO_PUNCTA_SEGMENTATION     = false
params.DO_TRACKING                = false   // Tile-level tracking
params.DO_TRACKING_MONTAGE        = false   // Montage-level tracking
params.DO_INTENSITY               = false
params.DO_CROP                    = false   // Object crops from raw images
params.DO_MASK_CROP               = false   // Object crops from mask images
params.DO_MONTAGE                 = false
params.DO_ALIGNMENT               = false
params.DO_PLATEMONTAGE            = false
params.DO_CNN                     = false
params.DO_GET_CSVS                = false
params.DO_OVERLAY                 = false   // Tile-level overlay
params.DO_OVERLAY_MONTAGE         = false   // Montage-level overlay - to visualize the selected ids


// ============================================================================
// 3. EXPERIMENT  (the main set of values most users edit)
// ============================================================================
params.experiment           = 'ALS-Set55-04172025TDP43EOS-JAK'   // Experiment name (must match DB / filenames)
params.morphology_channel   = 'FITC'                              // Channel used for segmentation/tracking
params.chosen_wells         = 'all'                               // 'all' or 'A1,A2,B3'
params.wells_toggle         = 'include'                           // 'include' | 'exclude'
params.chosen_timepoints    = 'T2-T12'                            // 'all' | 'T0' | 'T0-T7'
params.timepoints_toggle    = 'include'                           // 'include' | 'exclude'
params.chosen_channels      = 'all'                               // 'all' or 'FITC,RFP'
params.channels_toggle      = 'include'                           // 'include' | 'exclude'
params.use_aligned_tiles    = ''                                  // '' or 'true' to use aligned tiles
params.tile                 = 0                                   // 0 = all tiles; otherwise a tile index
params.analysis_version     = '1'                                 // Bump if rerunning to keep prior output
params.img_norm_name        = 'subtraction'                       // 'identity' | 'subtraction' | 'division'
params.dir_structure        = 'sub_dir'                           // 'root_dir' | 'sub_dir'


// ============================================================================
// 4. REGISTER EXPERIMENT  (only used when DO_REGISTER_EXPERIMENT = true)
// ============================================================================
params.input_path                       = '/gladstone/finkbeiner/robodata/IXM4Galaxy/Wesley/ALS-Set55-04172025TDP43EOS-JAK'
params.output_path                      = '/gladstone/finkbeiner/kaye/SheridanMoore/GXYTMP/Nextflow/Set55'
params.template_path                    = '/gladstone/finkbeiner/kaye/SheridanMoore/GXYTMP/Nextflow/Set55/Set55_ixm_template.xlsx'
params.ixm_hts_file                     = '/gladstone/finkbeiner/kaye/SheridanMoore/GXYTMP/Nextflow/Set55/ALS-Set55-04172025TDP43EOS-JAK.HTS'
params.platemap_path                    = '/gladstone/finkbeiner/kaye/SheridanMoore/GXYTMP/Nextflow/Set55/IXM-platemap_set55.csv'
params.illumination_file                = '/gladstone/finkbeiner/robodata/IXM-Documents/IXM-illumination-file-CB.ILS'
params.robo_file                        = '.'    // Legacy roboscope template (csv); '.' if IXM
params.robo_num                         = '0'    // [0, 3, 4]
params.chosen_channels_for_register_exp = 'all'  // Also used by Montage
params.overwrite_experiment             = '1'    // 0 = preserve existing, 1 = overwrite


// ============================================================================
// 5. SEGMENTATION  (threshold-based)
// ============================================================================
params.segmentation_method    = 'sd_from_mean'   // 'sd_from_mean' | 'triangle' | 'minimum' | 'yen'
params.lower_area_thresh      = 300              // Min cell area (px) — e.g. 100 or 30000 depending on dataset
params.upper_area_thresh      = 1000             // Max cell area (px)
params.sd_scale_factor        = 3.5              // For sd_from_mean: mean + sd_scale_factor * std
params.proximity_filter_radius = 30              // Remove cells within this px radius. 0 = disable.


// ============================================================================
// 6. CELLPOSE SEGMENTATION  (ML-based, GPU)
// ============================================================================
params.model_type           = 'nuclei'   // 'cyto' | 'nuclei' | 'cyto2'
params.batch_size_cellpose  = 16
params.cell_diameter        = 20         // Default ~30 px for cells; 5 for puncta
params.flow_threshold       = 0.8        // Cellpose default 0.4; 2 for puncta
params.cell_probability     = '-0.5'     // Cellpose default -2.0


// ============================================================================
// 7. PUNCTA SEGMENTATION
// ============================================================================
params.puncta_target_channel        = ['Epi-GFP16']   // Channels to process in parallel
params.puncta_segmentation_method   = 'triangle'      // 'triangle' | 'minimum' | 'yen' | 'manual'
params.sigma1                       = 2.5             // Smaller Gaussian blur (IXM ~2)
params.sigma2                       = 4               // Larger Gaussian blur (IXM ~3.2)
params.puncta_manual_thresh         = 2000            // Used when puncta_segmentation_method = 'manual'


// ============================================================================
// 8. TRACKING
// ============================================================================
params.distance_threshold   = 100        // Max px between matched cells (use ~5000 for proximity)
params.voronoi_bool         = true       // Use Voronoi cells for new-cell decision
params.USE_PROXIMITY        = true
params.USE_OVERLAP          = true
params.track_type           = 'overlap'  // 'overlap' | 'proximity' (montage tracking)
params.motion               = true       // Enable Kalman + Hungarian motion tracking


// ============================================================================
// 9. INTENSITY
// ============================================================================
params.target_channel = ['FITC', 'RFP']  // Channels to compute intensity on (parallel)


// ============================================================================
// 10. CROP
// ============================================================================
params.crop_size          = 300
params.target_channel_crop = ['FITC']    // Channels to crop (parallel)


// ============================================================================
// 11. MONTAGE / PLATE MONTAGE
// ============================================================================
params.tiletype                   = 'filename'   // 'filename' | 'maskpath' | 'trackedmaskpath'
params.montage_pattern            = 'standard'   // 'standard' (IXM) | 'legacy' (Robo4)
params.well_size_for_platemontage = 3000         // Per-well side length (px)
params.norm_intensity             = 50000        // Normalisation: (img / norm_intensity) * 255
params.image_overlap              = 10           // Tile overlap (px)


// ============================================================================
// 12. ALIGNMENT  (tile-level)
// ============================================================================
params.aligntiletype       = 'filename'   // 'filename' | 'maskpath'
params.alignment_algorithm = 'cross_correlation_dft_combo'   // 'cross_correlation' | 'dft' | 'cross_correlation_dft_combo'
params.imaging_mode        = 'epi'        // '' | 'epi' | 'confocal' (not needed for ROBO 3)
params.shift_dict          = 'null'       // Usually 'null'; otherwise mapping of channel shifts


// ============================================================================
// 13. CNN
// ============================================================================
params.cnn_model_type           = 'cnn_with_dropout'   // 'cnn' | 'cnn_with_bn' | 'cnn_with_dropout' | 'resnet'
params.label_type               = 'celltype'           // 'celltype' | 'name' | 'stimulate'
params.label_name               = ''                   // Dosage / treatment label (or '' for none)
params.classes                  = ''                   // Comma-separated class list (or '' for all)
params.img_norn_name_cnn        = 'identity'           // 'identity' | 'subtraction' | 'division'
params.filters                  = ['name', 'cry2mscarlet']   // [column_name, value] filter
params.chosen_channels_for_cnn  = 'Epi-RFP16'          // '' for all
params.num_channels             = 2                    // Input channels for the model
params.n_samples                = 0                    // 0 = all samples
params.epochs                   = 100                  // Training epochs
params.batch_size               = 64                   // 16/32/64/128 — GPU-permitting
params.learning_rate            = '1e-6'
params.momentum                 = 0.9                  // Only for SGD optimiser
params.optimizer                = 'adam'               // 'adam' | 'sgd'


// ============================================================================
// 14. OVERLAY (tile + montage)
// ============================================================================
params.shift                    = 10   // Text-label offset from cell centroid (px)
params.contrast                 = 4    // Image-contrast multiplier
// Optional: filter overlays to a subset of cell IDs.
//   - Set to '' to overlay all cells.
//   - Set to a comma-separated list (e.g. '5,12,23') to show just those IDs.
//   - Set to a CSV path with columns (well, tracked_id, timepoint) for a
//     per-well/per-timepoint filter (e.g. stable-cell CSVs).
// When set, output goes to Overlay_Montages_selected_ids (full overlays preserved).
params.overlay_montage_cell_ids = '/gladstone/finkbeiner/kaye/SheridanMoore/GXYTMP/Nextflow/ALS-Set55-04172025TDP43EOS-JAK/ALS-Set55-04172025TDP43EOS-JAK_tracked_montage_summary_stable_ids_1.csv'
